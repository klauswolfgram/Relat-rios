/*/
User Function QMTR060Val(cPad,cRev)
Local lRet:=.T.
Local aArea	:= GetArea()

dbSelectArea("QM3")
dbSetOrder(1)
If DBSeek(xFilial("QM3")+cPad)
	If QM3->QM3_REVPAD > cRev
		lRet:=.F.
	Endif
EndIf   

RestArea( aArea )
Return lRet

