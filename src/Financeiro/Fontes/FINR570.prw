User Function FINR570()

If TRepInUse()
	MPReport("FINR570","SET",STR0007,STR0002+CRLF+STR0003+STR0004,{STR0008})
Else
	Return U_FINR570R3() // Executa vers縊 anterior do fonte
Endif

Return






