User Function R160CkMes(nParam)
Local lRet := .F.,cCpo :=""

If naovazio()
	cCpo := "mv_par"+StrZero(nParam,2)
	cCpo := &cCpo
	If cCpo > 0 .And. cCpo <=12
		lRet := .T.
	EndIf
EndIf

Return(lRet)
