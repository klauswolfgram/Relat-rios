*/
Static Function TEC540Cobr( cNumOS, cItem, cSubItem )

Local nCobrado := 0		// valor cobrado

DbSelectArea("AB8")
DbSetOrder(1)
MsSeek(xFilial("AB8") + cNumOS + cItem  + cSubItem)

nCobrado := xMoeda(AB8->AB8_TOTAL,1,AB6->AB6_MOEDA) 

Return ( nCobrado )
