/*/
User Function QIPR110()
Local oReport
Private cPerg	:= "QPR110"
Private  __cPRODUTO := CriaVar("QP6_PRODUT") //Codigo do Produto, quando a Especificacao for em Grupo      
Private lProduto   := .F.

If TRepInUse()
	Pergunte(cPerg,.F.) 
    oReport := ReportDef()
    oReport:PrintDialog()
Else
    U_QIPR110R3() //Executa vers縊 anterior do fonte
EndIf

Return


