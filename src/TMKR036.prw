/*/  
User Function TMKR036()
Local oReport	//Objeto relatorio TReport (Release 4)

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳ Verifica as perguntas selecionadas                           ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
Pergunte("TMK036",.F.)

/*ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	ｳ Variaveis utilizadas para parametros                          ｳ
	ｳ Mv_Par01           // Campanha                                ｳ
	ｳ Mv_Par02           // Do Script                               ｳ
	ｳ Mv_Par03           // Ate Script                              ｳ
	ｳ Mv_Par04           // Da data                                 ｳ
	ｳ Mv_Par05           // Ate a Data                              ｳ
/*ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ*/


//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳInterface de impressaoｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
oReport := ReportDef()
oReport:PrintDialog() 

Return Nil            



/*
ﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ｱｱﾉﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾋﾍﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾋﾍﾍﾍﾍﾍﾍﾑﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｻｱｱ
ｱｱｺPrograma  ｳTKR036VlScｺAutor  ｳRafael M. Quadrotti ｺ Data ｳ  06/03/03   ｺｱｱ
ｱｱﾌﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾘﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾊﾍﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾊﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｹｱｱ
ｱｱｺDesc.     ｳValidacao dos scripts informados com relacao a campanha     ｺｱｱ
ｱｱｺ          ｳdefinida no MV_PAR01                                        ｺｱｱ
ｱｱﾌﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾘﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｹｱｱ
ｱｱｺUso       ｳ AP7                                                        ｺｱｱ
ｱｱﾈﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾏﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍﾍｼｱｱ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟ
*/
Static Function TKR036VlSc(nScripts,aScripts,cScripts)
Local lRet 		:= .F.			//	Retorno da Funcao
Local aSArea	:= GetArea()	//	Grava o alias anterior

DbSelectArea("SUW")
DbSetOrder(1)
If MsSeek(xFilial("SUW")+AllTrim(Mv_Par01))
	While	(!Eof())							.AND.;
			(xFilial("SUW")==SUW->UW_FILIAL)	.AND.;
			(SUW->UW_CODCAMP ==	 Mv_Par01   )
		//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
		//ｳArmazena todos os Scripts relacionados a campanha.ｳ
		//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		// aScripts[X][1] - Codigo do Script
		// aScripts[X][2] - Array com as perguntas deste Scripts
		// aScripts[X][3] - Array com as respostas deste Scripts
		Aadd(aScripts,{SUW->UW_CODSCRI,{},{}})
		SUW->(DbSkip())
	End
Endif

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳArmazena os Scripts selecionados nos parametos.ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
For nScripts := 1 To Len(aScripts)
	If (aScripts[nScripts][1] >= MV_PAR02) .AND. (aScripts[nScripts][1] <= MV_PAR03)
		cScripts+= "'" + aScripts[nScripts][1]+ "',"
	Endif
Next nScripts

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳTratamento para retirada da ', ' para a clausula IN do SQL.ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
cScripts := SubStr(cScripts,1, Len(cScripts)-1)

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳSe esta variavel estiver vazia os scripts definidos nos parametros        ｳ
//ｳestao incorretos. O sistema so permitira a impressao dos relatorios se os ｳ
//ｳscripts informados estiverem corretos.                                    ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
If Empty(cScripts)
	lRet := .F.
Else
	lRet := .T.	
EndIf

RestArea(aSArea)
Return (lRet)
                                   

/*/
ﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ｱｱﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿｱｱ
ｱｱｳFun㊤o    ReportDef ｳ Autor ｳMichel W. Mosca     ｳ Data ｳ01/08/2007ｳｱｱ
ｱｱﾃﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾅﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｴｱｱ
ｱｱｳDescri㊤o ｳRotina que define os itens que serao apresentados no relato-ｳｱｱ
ｱｱｳ          ｳrio de Resultado de Scripts Din穃icos no release 4.         ｳｱｱ
ｱｱﾃﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾅﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｴｱｱ
ｱｱｳSintaxe   ｳ ReportDef(ExpN1, ExpA2, ExpC3)                          ｳｱｱ
ｱｱﾃﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾅﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｴｱｱ
ｱｱｳParametrosｳExpN1 = Numero de scripts da campanha selecionada           ｳｱｱ
ｱｱｳ          ｳExpN2 = Array contendo dados dos scripts                    ｳｱｱ
ｱｱｳ          ｳExpC3 = codigos dos scripts para consulta ao DB.            ｳｱｱ
ｱｱﾃﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾅﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｴｱｱ
ｱｱｳ Uso      ｳ Generico                                                   ｳｱｱ
ｱｱﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙｱｱ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟ
*/                       
Static Function ReportDef()
Local oReport			//Objeto relatorio TReport (Release 4)
Local oSection1 		//Objeto secao 1 do relatorio (Dados do script da campanha)
Local oSection2 		//Objeto secao 2 do relatorio (Perguntas associadas ao script)
Local oSection3 		//Objeto secao 3 do relatorio (Repostas as perguntas)
Local cACI := GetNextAlias() 	// Gerencia o alias entre top e dbf
Local cSUK := cACI 	// Gerencia o alias entre top e dbf
Local nScripts	:= 0	// Contador do For.
Local aScripts	:= {}	// Array com os scripts que estao definidos no item da Campanha selecionada.
Local cScripts	:= ""	// String com os codigos dos Scripts selecionados.


// "Resultado de Scripts Dinamicos" # // "Este programa ira emitir uma relacao dos Scripts dinamicos"
// "totalizando todas das respostas dadas de acordo com o" # // "periodo e Campanhas definidas. "
DEFINE REPORT oReport NAME "TMKR036" TITLE STR0001 PARAMETER "TMK036" ACTION {|oReport| Tkr036PrtRpt( oReport, @nScripts,@aScripts,@cScripts, cACI, cSUK)} DESCRIPTION STR0002 + STR0003 + STR0004


//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳDefine a secao1 do relatorio, informando que o arquivo principal ｳ 
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
DEFINE SECTION oSection1 OF oReport TITLE STR0032  		//"Dados do script da campanha"
DEFINE SECTION oSection2 OF oSection1 TITLE STR0033 	//"Perguntas associadas ao script"
DEFINE SECTION oSection3 OF oSection2 TITLE STR0034 	//"Repostas as perguntas"


//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳDefine as celulas que irao aparecer na secao1ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
DEFINE CELL NAME "S1_SCRIPT"	OF oSection1 TITLE STR0010 SIZE 70

DEFINE CELL NAME "S2_PERGUNT"	OF oSection2 TITLE STR0013 SIZE 70 LINE BREAK

DEFINE CELL NAME "S3_RESP"		OF oSection3 TITLE STR0014 SIZE 70 LINE BREAK
DEFINE CELL NAME "S3_SCORE"		OF oSection3 TITLE STR0011 SIZE 10
DEFINE CELL NAME "S3_TOT"		OF oSection3 TITLE STR0012 SIZE 10
DEFINE CELL NAME "S3_OBS"		OF oSection3 TITLE STR0031 SIZE 70 LINE BREAK 

Return(oReport)   

/*/
ﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜﾜ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ｱｱﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾂﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿｱｱ
ｱｱｳFun㊤o    ｳTkr036PrtRpt ｳ Autor ｳMichel W. Mosca     ｳ Data ｳ01/08/2007ｳｱｱ
ｱｱｳ          ｳ             ｳ       ｳ                    ｳ      ｳ          ｳｱｱ
ｱｱﾃﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾅﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｴｱｱ
ｱｱｳDescri㊤o ｳRotina responsavel pela impressao do relatorio de Resultadosｳｱｱ
ｱｱｳ          ｳde Scripts Dinamicos  no release 4.                         ｳｱｱ
ｱｱﾃﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾅﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｴｱｱ
ｱｱｳSintaxe   ｳ Tkr036PrtRept(ExpO1,ExpN1,ExpN2,ExpC3,ExpC4,ExpC5)         ｳｱｱ
ｱｱﾃﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾅﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｴｱｱ
ｱｱｳParametrosｳ ExpO1 = objeto relatorio                                   ｳｱｱ
ｱｱｳ          ｳ ExpN1 = Numero de scripts da campanha selecionada          ｳｱｱ
ｱｱｳ          ｳ ExpN2 = Array contendo dados dos scripts                   ｳｱｱ
ｱｱｳ          ｳ ExpC3 = codigos dos scripts para consulta ao DB.           ｳｱｱ
ｱｱｳ          ｳ ExpC4 = alias da query atual ACI                           ｳｱｱ
ｱｱｳ          ｳ ExpC5 = alias da query atual SUK                           ｳｱｱ
ｱｱﾃﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾅﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｴｱｱ
ｱｱｳ Uso      ｳ Generico                                                   ｳｱｱ
ｱｱﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾁﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙｱｱ
ｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱｱ
ﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟﾟ
*/
Static Function Tkr036PrtRpt(oReport, nScripts, aScripts, cScripts, cACI, cSUK)
Local oSection1 := oReport:Section(1) 		//Objeto secao 1 do relatorio (Dados do script da campanha)
Local oSection2 := oSection1:Section(1)		//Objeto secao 2 do relatorio (Perguntas associadas ao script)
Local oSection3 := oSection2:Section(1)    //Objeto secao 3 do relatorio (Repostas as perguntas)


Local cFiltro	:= ""   					//String contendo o filtro de busca a ser utilizado com DBF   

//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳDeclaracao de variaveis especificas para este relatorioｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
Local nI		   := 0			// Contador
Local aLinhas	   := {}		// Recebe as linhas do memo
Local dDatIniCamp  :=CtoD("//")	// Data Inicial da vigencia da Campanha
Local dDatFimCamp  :=CtoD("//")	// Data Final de vigencia da Campanha
Local aPergunta    := {}		// Array auxiliar para as perguntas
Local aResposta    := {}		// Array auxiliar para as Respostas
Local nPosResp	   := 0			// Retorno de AsCan
Local nPosScript   := 0			// Retorno do AsCan
Local aRespTemp    := {}		// Array temporario de respostas para utilizacao do contador.
Local lDado        := .F.		// Flag para identificar se existem dados para impressao.
Local cCodPerg     := ""		// Codigo da pergunta relacionada a resposta
Local nPosPerg     := 0			// Posicao da pergunta.
Local nW           := 0			// Controle de for para impressao de Memo.
Local nLenAux	   := 0 		// Contador auxilar para o FOR
Local cAuxObs					//Armazena o conteudo da resposta informada pelo usu疵io
Local cStringAux    := ""		//Var auxiliar para tirar aspas simples da string


//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
//ｳLaco para verificacao dos parametros digitados.ｳ
//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
If !TKR036VlSc(@nScripts,@aScripts,@cScripts)
		Aviso(STR0029,STR0030,{"OK"}) //"Pergunte"###"Os Par穃etros de Scripts nao pertencem a campanha definida."
		oReport:PrintText(STR0035+STR0029+" "+STR0030+" "+STR0036) //"Falha: "    /"Verifique os par穃etros para a impress縊 do relatio."
Else
	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳVerifica se a Campanha foi preenchida para pesquisa dos Scripts que estao no itens. ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	
	If !Empty(Mv_Par01)
		//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
		//ｳArmazena as datas de vigencia da campanha para validacao do periodo para impressao.ｳ
		//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		DbSelectArea("SUO")
		DbSetOrder(1)
		If MsSeek(xFilial("SUO")+AllTrim(Mv_Par01))
			dDatIniCamp:= SUO-> UO_DTINI
			dDatFimCamp:= SUO-> UO_DTFIM
		Endif
	Endif
	
	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳValidacao da data inical para selecao dos resultados.          ｳ
	//ｳAs datas de inicio e fim devem respeitar as datas definidas na ｳ
	//ｳcampanha.                                                      ｳ
	//ｳSe Data Inicial da Campanha  > que data do Parametro Dt Inicialｳ
	//ｳ     Data Inicial valida = Data Inicial da Campanha            ｳ
	//ｳSenao                                                          ｳ
	//ｳ     Data Inicial valida = Data do Parametro Dt Inicial        ｳ
	//ｳFimSe                                                          ｳ
	//ｳ                                                               ｳ
	//ｳSe Data Final da Campanha  < que data do Parametro Dt Final    ｳ
	//ｳ     Data Final valida = Data Final da Campanha                ｳ
	//ｳSenao                                                          ｳ
	//ｳ     Data Final valida = Data do Parametro Dt Final            ｳ
	//ｳFimSe                                                          ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	
	If (dDatIniCamp < MV_PAR04) .OR. Empty(dDatIniCamp)
		dDatIniCamp := MV_PAR04
	Endif
	
	If (dDatFimCamp > MV_PAR05)	.OR. Empty(dDatFimCamp)
		dDatFimCamp := MV_PAR05
	Endif
	
	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳPara cada Script serao armazenadas as Perguntas e Respostasｳ
	//ｳonde serao tambem totalizadas as respostas.                ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳCarrega as perguntas e repostas.ｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	DbSelectArea("SUP")
	DbSetOrder(1)               
	nLenAux := Len(aScripts)
	For nScripts := 1 To nLenAux
		
		If MsSeek(xFilial("SUP") + aScripts[nScripts][1])
			
			While (!Eof()) 							 		.AND.;
				 (xFilial("SUP") == SUP->UP_FILIAL) 		.AND.; 
				 (aScripts[nScripts,1] == SUP->UP_CODCAMP)
				
				If !Empty(SUP->UP_TIPOOBJ)
					//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
					//ｳAPERGUNTA                                                                ｳ
					//ｳ1- UP_CODCAMP	-	Codigo do Script                                    ｳ
					//ｳ2- UP_CARGO	    -	Codigo do Item                                      ｳ
					//ｳ3- UP_IDTREE	    -	Cargo Pai deste Item. (em que ele esta amarrado)    ｳ
					//ｳ4- UP_DESC		-   Descricao da resposta.                              ｳ
					//ｳ5- UP_CODOBS	    -   Codigo da Observacao da pergunta                    ｳ
					//ｳ6- UP_SCORE	    -   Pontuacao da resposta no cadastro de Scripts        ｳ
					//ｳ7- UP_TIPOOBJ	-   Tipo da Resposta ('1','2' ou '3')                   ｳ
					//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
					
					Aadd(aPergunta,{UP_CODCAMP	,;	//	 Codigo do Script
									UP_CARGO	,;	//	 Cargo do Item.
									UP_IDTREE	,;	//	 Cargo Pai deste item. (em quem ele esta amarrado)
									UP_DESC		,;
									UP_CODOBS	,;
									UP_SCORE	,;
									UP_TIPOOBJ})      
	
					//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
					//ｳSe o tipo de resposta for dissertativa nao ha uma referencia ｳ
					//ｳna base de dados para a resposta pois a informacao fica      ｳ
					//ｳarmazenada na pergunta. Neste caso crio uma posicao          ｳ
					//ｳpara resposta dissetativa para armazenamento das informacoes ｳ
					//ｳdigitadas.                                                   ｳ
					//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
					If SUP->UP_TIPOOBJ == "3" 
						Aadd(aResposta,{	UP_CODCAMP	,; //	Codigo do Script
											"00000000"	,; //	Codigo do Item
											UP_CARGO	,; //	Cargo Pai deste Item. (em que ele esta amarrado) - utilizado o cargo da pergunta
											""			,;
											""			,;
											0			,; //	Score
											""			,;
											0			,; //	Pontuacao de cada resposta.
											{}			})
					Endif								
					
				Else
					
					//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
					//ｳARESPOSTA                                                                ｳ
					//ｳ1- UP_CODCAMP	-	Codigo do Script                                    ｳ
					//ｳ2- UP_CARGO	    -	Codigo do Item                                      ｳ
					//ｳ3- UP_IDTREE	    -	Cargo Pai deste Item. (em que ele esta amarrado)    ｳ
					//ｳ4- UP_DESC		-   Descricao da resposta.                              ｳ
					//ｳ5- UP_CODOBS	    -   Codigo da Observacao da resposta                    ｳ
					//ｳ6- UP_SCORE	    -   Pontuacao da resposta no cadastro de Scripts        ｳ
					//ｳ7- UP_TIPOOBJ	-   Tipo da Resposta ('1','2' ou '3')                   ｳ
					//ｳ8- 0             -  	Pontuacao de cada resposta.                         ｳ
					//ｳ9- Array         -  	Array com os textos referentes a resposta.          ｳ
					//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
					
					Aadd(aResposta,{	UP_CODCAMP	,; //	Codigo do Script
										UP_CARGO	,; //	Codigo do Item
										UP_IDTREE	,; //	Cargo Pai deste Item. (em que ele esta amarrado)
										UP_DESC		,;
										UP_CODOBS	,;
										UP_SCORE	,;
										UP_TIPOOBJ	,;
										0			,; //	Pontuacao de cada resposta.
										{}			})
				Endif
				
				DbSkip()
			End
			
		Endif
	
		aScripts[nScripts][2] := aPergunta
		aScripts[nScripts][3] := aResposta
		
		//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
		//ｳLimpa as informacoes para o proximo script.ｳ
		//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		aPergunta := {}
		aResposta := {}
		
	Next nScripts
		
	MakeSqlExpr("TMKR006")      
	
	cScriptsAux :=SubStr(cScripts,2, Len(cScripts)-2)

	BEGIN REPORT QUERY oSection1
	BeginSQL alias cACI                          	
			SELECT ACI_FILIAL,		ACI_CODCAM,		ACI_CODSCR,		ACI_CODSCR,
					ACI_DATA,			ACI_CODIGO,		UK_FILIAL,		UK_CODIGO,
					UK_CODPERG,		UK_CODRESP,		UK_CODMEMO		           
			FROM %table:ACI% ACI,	%table:SUK% SUK 

			WHERE	ACI.ACI_FILIAL = %xFilial:ACI% 		AND
					ACI.ACI_CODCAM = %exp:Mv_Par01%    	AND
					ACI.ACI_CODSCR IN(%exp:cScriptsAux%) 	AND
					ACI.ACI_DATA BETWEEN %exp:DtoS(dDatIniCamp)%	AND %exp:DtoS(dDatFimCamp)%		AND
					ACI.%notDel%						 AND
					SUK.UK_FILIAL = %xFilial:SUK% 		 AND
					SUK.UK_CODIGO = ACI.ACI_CODIGO 		 AND
					SUK.%notDel%				
			ORDER BY %order:ACI%
	EndSql    
	END REPORT QUERY oSection1      
	
	While	(!Eof())								.AND.;
			(cACI)->ACI_FILIAL == xFilial("ACI")	.AND.;
			(cACI)->ACI_CODCAM == Mv_Par01			.AND.;
			(cACI)->ACI_CODSCR >= Mv_PAR02			.AND.;
			(cACI)->ACI_CODSCR <= Mv_PAR03
		
	    oReport:IncMeter()
		
		If oReport:Cancel()
			Exit
		EndIf
					
		//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
		//ｳVerifico a posico do Script que esta sendo trabalhado no ｳ
		//ｳarray de Scripts que serao emitidos.                     ｳ
		//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		nPosScript := Ascan(aScripts,{|aVal| aVal[1] = (cACI)->ACI_CODSCR})
		
		aRespTemp := aScripts[nPosScript][3]
		
		//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
		//ｳPesquisa em todo o array de respostas (aResposta) a resposta gravada no SUK		ｳ
		//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
		//ｳARESPOSTA                                                                ｳ
		//ｳ1- UP_CODCAMP	-	Codigo do Script                                    ｳ
		//ｳ2- UP_CARGO	    -	Codigo do Item                                      ｳ
		//ｳ3- UP_IDTREE	    -	Cargo Pai deste Item. (em que ele esta amarrado)    ｳ
		//ｳ4- UP_DESC		-   Descricao da resposta.                              ｳ
		//ｳ5- UP_CODOBS	    -   Codigo da Observacao da resposta                    ｳ
		//ｳ6- UP_SCORE	    -   Pontuacao da resposta no cadastro de Scripts        ｳ
		//ｳ7- UP_TIPOOBJ	-   Tipo da Resposta ('1','2' ou '3')                   ｳ
		//ｳ8- 0             -  	Pontuacao de cada resposta.                         ｳ
		//ｳ9- Array         -  	Array com os textos referentes a resposta.          ｳ
		//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		cCodPerg := (cSUK)->UK_CODPERG
		nPosResp := Ascan(aRespTemp,{|aVal| aVal[2] = (cSUK)->UK_CODRESP})
	
		//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
		//ｳCaso a resposta seja encontrada sera contabilizada.ｳ
		//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		If nPosResp > 0
			lDado := .T.
			
			//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
			//ｳVerifica se o tipo de objeto da resposta eh memo.                       ｳ
			//ｳPara saber se esta resposta utiliza memo (respostas dissertativas)      ｳ
			//ｳsera verificada a pergunta a ela relacionada que contem esta informacao.ｳ
			//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
			//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
			//ｳAPERGUNTA                                                                ｳ
			//ｳ1- UP_CODCAMP	-	Codigo do Script                                    ｳ
			//ｳ2- UP_CARGO	    -	Codigo do Item                                      ｳ
			//ｳ3- UP_IDTREE	    -	Cargo Pai deste Item. (em que ele esta amarrado)    ｳ
			//ｳ4- UP_DESC		-   Descricao da resposta.                              ｳ
			//ｳ5- UP_CODOBS	    -   Codigo da Observacao da pergunta                    ｳ
			//ｳ6- UP_SCORE	    -   Pontuacao da resposta no cadastro de Scripts        ｳ
			//ｳ7- UP_TIPOOBJ	-   Tipo da Resposta ('1','2' ou '3')                   ｳ
			//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
								
			nPosPerg := Ascan(aScripts[nPosScript][2],{|aVal| aVal[2] = cCodPerg})
			If aScripts[nPosScript][2][nPosPerg][7] <> '3' // Diferente de Memo 
				
				aScripts[nPosScript][3][nPosResp][8]+= 1
				//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
				//ｳTratamento para impressao do memo de resposta aberta.ｳ
				//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
				If Alltrim(aScripts[nPosScript][3][nPosResp][4]) == STR0008 //"RESPOSTA ABERTA"
					Aadd(aScripts[nPosScript][3][nPosResp][9],(cSUK)->UK_CODMEMO)
				Endif
			
			Else
				nPosResp := Ascan(aRespTemp,{|aVal| aVal[3] = cCodPerg})
				If nPosResp > 0
					If (aScripts[nPosScript][3][nPosResp][3] = cCodPerg)
						Aadd(aScripts[nPosScript][3][nPosResp][9],(cSUK)->UK_CODMEMO)
					Endif	
				Endif	
			Endif
		
		Endif
		
		// Limpa variaveis auxiliares
		nPosResp := 0
		aRespTemp:= {}
	
		DbSelectArea(cACI)
		DbSkip()
	End
	
	//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
	//ｳQuebra a linha, caso existam muitas colunasｳ
	//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
	oSection1:SetLineBreak()
	oSection2:SetLineBreak()
		
	
	If lDado
		
		//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
		//ｳImpressao dos dados da campanhaｳ
		//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		oReport:FatLine()
		oReport:PrintText(STR0009 + MV_PAR01+ "-"+ Posicione("SUO",1,xFilial("SUO") + MV_PAR01,"UO_DESC"))		
		oReport:FatLine()		
		
		For nScripts := 1 To Len(aScripts)
					
			//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
			//ｳ Verifico se o script faz parte dos scripts selecionados  ｳ
			//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
			If !( aScripts[nScripts][1] $ cScripts)
				Loop
			Endif
		
			//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
			//ｳ Impressao do Titulo do Script Dinamico                   ｳ
			//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
		
		//S1_SCRIPT	
			oSection1:Init()
			oSection1:Cell("S1_SCRIPT"):SetValue(aScripts[nScripts][1]+ "-"+ Posicione("SUZ",1,xFilial("SUZ") + aScripts[nScripts][1],"UZ_DESC"))
			oSection1:PrintLine()	
			
			//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
			//ｳ Laco para impressao das perguntas.                       ｳ
			//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
			// aScripts[x][1] - Codigo do Script
			// aScripts[x][2] - Array com as perguntas deste Scripts
			// aScripts[x][3] - Array com as respostas deste Scripts
		                                       
		
			For nPosPerg := 1 To Len(aScripts[nScripts][2]) // Perguntas
		
		//S2_PERGUNT
				oSection2:Init()
				oSection2:Cell("S2_PERGUNT"):SetValue(aScripts[nScripts][2][nPosPerg][4])
				oSection2:PrintLine()
				
				
				//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
				//ｳ Inicio da impressao das respostas.                       ｳ
				//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
				//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
				//ｳ Laco para impressao das respostas.                       ｳ
				//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
				oSection3:Init()                
				For nPosResp:= 1 To Len(aScripts[nScripts][3])
					//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
					//ｳ Se a resposta for relacionada com a pergunta             ｳ
					//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
			 		
					If aScripts[nScripts][3][nPosResp][3] == aScripts[nScripts][2][nPosPerg][2]
						
						//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
						//ｳ Se o tipo de dados for diferente de Memo                 ｳ
						//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
						If aScripts[nScripts][2][nPosPerg][7] <> '3' // Memo        
							
							oSection3:Cell("S3_RESP" ):Enable()
							oSection3:Cell("S3_SCORE"):Enable()
							oSection3:Cell("S3_TOT"  ):Enable()
							oSection3:Cell("S3_OBS"  ):Disable()
								
							oSection3:Cell("S3_RESP" ):SetValue(aScripts[nScripts][3][nPosResp][4])
							oSection3:Cell("S3_SCORE"):SetValue(Transform(aScripts[nScripts][3][nPosResp][6],"99999"))
							oSection3:Cell("S3_TOT"  ):SetValue(Transform(aScripts[nScripts][3][nPosResp][8],"99999"))							
							
						Else
							//ﾚﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄｿ
							//ｳ Se existirem dados para serem impressos sera executado um laco	 ｳ
							//ｳ para todos estes dados e a funcao TkMemo que retorna esta		 ｳ 
							//ｳ informacao.												 		 ｳ
							//ﾀﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾄﾙ
							If Len(aScripts[nScripts][3][nPosResp][9]) > 0								

								oSection3:Cell("S3_RESP" ):Disable()
								oSection3:Cell("S3_SCORE"):Disable()
								oSection3:Cell("S3_TOT"  ):Disable()					
								oSection3:Cell("S3_OBS"  ):Enable()
								
								cAuxObs := ""
								For nW := 1 To Len(aScripts[nScripts][3][nPosResp][9])
									aLinhas := TkMemo(aScripts[nScripts][3][nPosResp][9][nW],999)
									For nI := 1 to Len(aLinhas)
										cAuxObs += aLinhas[nI] + " " + CRLF
									Next nI
								Next nW

								oSection3:Cell("S3_OBS"):SetValue(cAuxObs)															

							EndIf
						Endif
						oSection3:PrintLine()	
					Endif
					
				Next nPosResp
				oSection3:Finish()					
				oSection2:Finish()		
			Next nPosPerg
			
			oSection1:Finish()		
		Next nScripts
	Else
		oReport:PrintText(STR0015)	//"Nao Existem dados a serem impressos para este relatorio com os parametros informados"
	EndIf	
EndIf

Return(.T.)