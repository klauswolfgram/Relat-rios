0005#STR0005#ALL#Legenda -
0006#STR0006#ALL#01 - Tempo Disponivel, de acordo com a escala
0007#STR0007#ALL#02 - Tempo Ausente
0008#STR0008#ALL#03 - Tempo Efetivo = Tempo Disponivel - Tempo Ausente
0009#STR0009#ALL#04 - Tempo Sem Aplicacao ou parado
0010#STR0010#ALL#05 - Tempo Aplicado ou Trabalhado
0011#STR0011#ALL#06 - Tempo Extra, ou Tempo Aplicado FORA da escala normal
0012#STR0012#ALL#07 - Tempo Estourado, ou total do tempo de execucao fora da tabela
0013#STR0013#ALL#08 - Tempo Padrao
0014#STR0014#ALL#09 - Tempo Cobrado, ou Tempo Padrao com Acrescimos ou Descontos
0015#STR0015#ALL#10 - Tempo que realmente foi Vendido
